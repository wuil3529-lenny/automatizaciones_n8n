    {
      "parameters": {
        "jsCode": "/**\n * NORMALIZADOR v9.5 - ANTI-BAD REQUEST\n */\nconst msg = $json.message || $json.edited_message || $json.callback_query?.message || {};\nconst text = msg.text || $json.callback_query?.data || \"\";\nconst caption = msg.caption || \"\";\nconst voice = msg.voice || msg.audio || null;\nconst photo = msg.photo || null;\nconst chat_id = msg.chat?.id || $json.callback_query?.from?.id || null;\n\nreturn {\n  chat_id,\n  text,\n  caption,\n  voice,\n  photo,\n  type: voice ? 'voice' : (photo ? 'photo' : 'text'),\n  chatInput: voice ? \"[Audio Transcrito]\" : (photo ? (caption || \"Analiza esta imagen\") : text)\n};"
      },
      "id": "b21497ff-f612-4fa3-9e7f-a6724a0cfcee",
