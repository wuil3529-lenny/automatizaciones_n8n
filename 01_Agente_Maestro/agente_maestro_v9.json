    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// STT via Gemini API - reemplaza nodo googleGemini no disponible\nconst binaryData = $binary?.data;\nif (!binaryData) {\n  return [{ json: { text: \"\", error: \"No binary data found\" } }];\n}\n\n// Obtener el API key de la credencial o variable de entorno\nconst apiKey = $env?.GOOGLE_API_KEY || $env?.GEMINI_API_KEY;\nif (!apiKey) {\n  throw new Error(\"Falta GOOGLE_API_KEY en las variables de entorno de n8n\");\n}\n\n// Los datos binarios vienen en base64\nconst base64Audio = binaryData.data;\nconst mimeType = binaryData.mimeType || \"audio/ogg\";\n\n// Llamar a la API de Gemini\nconst response = await $http.request({\n  method: \"POST\",\n  url: `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`,\n  headers: { \"Content-Type\": \"application/json\" },\n  body: JSON.stringify({\n    contents: [{\n      parts: [\n        {\n          inline_data: {\n            mime_type: mimeType,\n            data: base64Audio\n          }\n        },\n        {\n          text: \"Transcribe el audio exactamente como se dice. Solo devuelve el texto transcrito, sin explicaciones.\"\n        }\n      ]\n    }],\n    generationConfig: {\n      temperature: 0,\n      maxOutputTokens: 2048\n    }\n  })\n});\n\nconst transcript = response?.candidates?.[0]?.content?.parts?.[0]?.text || \"\";\nreturn [{ json: { text: transcript } }];"
      },
