    {
      "parameters": {
        "name": "operar_excel",
        "description": "DEBES utilizar esta herramienta para LEER, ESCRIBIR o CALCULAR datos en el Excel. No respondas sin usarla.",
        "workflowId": "PEGAR_ID_EXCEL_V60",
        "specifyInputSchema": true,
        "inputSchema": "{\"type\":\"object\",\"properties\":{\"archivo_detectado\":{\"type\":\"string\",\"description\":\"Opcional si ya hay uno seleccionado.\"},\"operacion\":{\"type\":\"string\",\"enum\":[\"lectura\",\"actualizar\",\"agregar_fila\",\"agregar_columna\",\"calculos\"]},\"filtro_filas\":{\"type\":\"string\",\"description\":\"Texto para buscar la fila a actualizar o leer.\"},\"filtro_columnas\":{\"type\":\"string\",\"description\":\"Nombre de la columna exacta para hacer calculos.\"},\"datos\":{\"type\":\"object\",\"description\":\"JSON con {columna: valor} para agregar fila, actualizar fila, o el valor por defecto para nueva columna (ej: {'NuevaCol': 'Valor'}).\"}},\"required\":[\"operacion\"]}"
      },
      "id": "tool_excel_v60",
      "name": "operar_excel",
      "type": "@n8n/n8n-nodes-langchain.toolWorkflow",
      "typeVersion": 1.2,
      "position": [
        1950,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "/**\n * SANITIZADOR HTML v60.8 - STABLE\n */\nlet raw = $input.first().json.output || \"\";\nlet text = raw.toString()\n  .replace(/This message was sent automatically with n8n\\.?/gi, '')\n  .trim();\n\n// 1. Escapar caracteres HTML básicos para evitar errores de parseo\ntext = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');\n\n// 2. Convertir negritas de Markdown (**text**) a HTML (<b>text</b>)\ntext = text.replace(/\\*\\*(.*?)\\*\\*/g, '<b>$1</b>');\n\n// 3. Detectar tabla de Markdown y envolverla en <pre> para monoespaciado en Telegram\nif (text.includes('| ---')) {\n    const lines = text.split('\\n');\n    let inTable = false;\n    let newText = [];\n    \n    for (const line of lines) {\n        if (line.trim().startsWith('|')) {\n            if (!inTable) {\n                newText.push('<pre>');\n                inTable = true;\n            }\n            newText.push(line);\n        } else {\n            if (inTable) {\n                newText.push('</pre>');\n                inTable = false;\n            }\n            newText.push(line);\n        }\n    }\n    if (inTable) newText.push('</pre>');\n    text = newText.join('\\n');\n}\n\nreturn {\n  id_chat: $('Unificador Sesión').first().json.id_chat,\n  texto_final: text || \"Hubo un error al procesar tu solicitud.\"\n};"
      },
      "id": "cleaner_v60",
      "name": "Sanitizador Salida",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.id_chat }}",
        "text": "={{ $json.texto_final }}",
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
