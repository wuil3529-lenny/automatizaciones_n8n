      "id": "f3a62cea-fb5c-435f-9962-5cda5df7271c",
      "name": "Set Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "/**\n * SHELL LOGIC v9.2 - MEMORY SAFE\n */\nconst items = $input.all().map(i => i.json);\nconst config = $('Parser V9.2').first().json;\nlet datos = [...items];\nlet msj = '';\nlet needUpdate = false;\n\nlet regex = null;\nif (config.filtro) {\n    regex = new RegExp(config.filtro, 'i');\n}\n\nswitch(config.operacion) {\n    case 'calculos':\n        if (config.columna) {\n            let suma = 0, count = 0;\n            items.forEach(r => {\n                const v = parseFloat(String(r[config.columna] || 0).replace(',', '.'));\n                if (!isNaN(v)) { suma += v; count++; }\n            });\n            msj = `Cálculo sobre '${config.columna}': Suma = ${suma}, Promedio = ${count > 0 ? (suma/count).toFixed(2) : 0}`;\n        }\n        break;\n\n    case 'actualizar':\n        if (config.datos && regex) {\n            let count = 0;\n            datos = items.map(r => {\n                if (Object.values(r).some(v => regex.test(String(v)))) {\n                    count++;\n                    return { ...r, ...config.datos };\n                }\n                return r;\n            });\n            msj = `Se actualizaron ${count} filas.`;\n            needUpdate = true;\n        }\n        break;\n\n    case 'agregar_fila':\n        if (config.datos) {\n            datos.push(config.datos);\n            msj = 'Fila agregada.';\n            needUpdate = true;\n        }\n        break;\n\n    case 'agregar_columna':\n        if (config.datos) {\n            const colName = Object.keys(config.datos)[0];\n            const defaultVal = config.datos[colName];\n            datos = items.map(r => ({ ...r, [colName]: defaultVal }));\n            msj = `Columna '${colName}' agregada.`;\n            needUpdate = true;\n        }\n        break;\n}\n\n// Limit result size for the AI to avoid memory issues\nconst filtered = regex ? datos.filter(r => Object.values(r).some(v => regex.test(String(v)))) : datos;\n\nreturn {\n  estado: 'EXITO',\n  mensaje: msj,\n  resultados: filtered.slice(0, 5), // Truncated to 5 rows for AI safety\n  conteo_total: filtered.length,\n  __full_data: datos, // Stays in memory but not passed back to AI if using logic\n  __need_sync: needUpdate\n};"
      },
