    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0 || Object.keys(items[0].json).length === 0) return [{ json: { response: { mensaje: 'No hay datos o no se encontraron archivos.' } } }];\nconst prim = items[0].json;\nif (prim.estado !== undefined) {\n  return [{ json: { response: {\n    estado: prim.estado,\n    mensaje: prim.mensaje || '',\n    resultados_muestra: prim.resultados || prim.resultados_muestra || [],\n    total_filas: prim.conteo_total || prim.total_filas || 0,\n    file_id: prim.file_id || ''\n  }} }];\n}\nif (prim.id && prim.name) {\n  return [{ json: { response: {\n    estado: 'EXITO',\n    mensaje: 'Archivos encontrados',\n    resultados_muestra: items.slice(0, 15).map(i => ({ id: i.json.id, name: i.json.name })),\n    total_filas: items.length\n  }} }];\n}\nreturn [{ json: { response: { resultados_muestra: items.map(i => i.json).slice(0, 10) } } }];"
      },
